<div class="fig-wrap">
  <div class="fig-label">FIGURE 03 — AGENT IDENTITY CREDENTIAL</div>
  <div class="card-layout">
    <div class="card-left">
      <div class="card-header">
        <div class="card-avatar">AI</div>
        <div>
          <div class="card-handle">papi.evm</div>
          <div class="card-did">did:erc8004:0x7f2c...6D33</div>
        </div>
        <div class="risk-badge risk-low">LOW RISK</div>
      </div>
      <div class="card-stats">
        <div class="stat">
          <div class="stat-value">2,841</div>
          <div class="stat-label">Tasks Completed</div>
        </div>
        <div class="stat">
          <div class="stat-value">98.3%</div>
          <div class="stat-label">Success Rate</div>
        </div>
        <div class="stat">
          <div class="stat-value">$47,200</div>
          <div class="stat-label">Value Processed</div>
        </div>
        <div class="stat">
          <div class="stat-value">127</div>
          <div class="stat-label">Days Active</div>
        </div>
      </div>
      <div class="card-section-label">ATTESTATIONS</div>
      <div class="attestations">
        <div class="attest attest-ok">✓ Deployer: EVM Systems</div>
        <div class="attest attest-ok">✓ Model: Claude Sonnet 4.6</div>
        <div class="attest attest-ok">✓ Runtime: OpenClaw v2</div>
        <div class="attest attest-ok">✓ KYA verified · Privado.id</div>
        <div class="attest attest-warn">⚠ Financial limit: $500/tx</div>
      </div>
    </div>
    <div class="card-right">
      <div class="card-section-label">RECENT ACTIVITY LOG</div>
      <div class="log">
        <div class="log-entry">
          <span class="log-time">20:29</span>
          <span class="log-ok">✓</span>
          <span class="log-text">Pinned IPFS build to Pinata</span>
        </div>
        <div class="log-entry">
          <span class="log-time">20:15</span>
          <span class="log-ok">✓</span>
          <span class="log-text">Pushed to GitHub main</span>
        </div>
        <div class="log-entry">
          <span class="log-time">19:52</span>
          <span class="log-ok">✓</span>
          <span class="log-text">Built Astro static site</span>
        </div>
        <div class="log-entry">
          <span class="log-time">14:07</span>
          <span class="log-ok">✓</span>
          <span class="log-text">Formatted 3 blog posts</span>
        </div>
        <div class="log-entry">
          <span class="log-time">13:04</span>
