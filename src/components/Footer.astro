---
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t-2 border-dead-black bg-cream">
  <div class="max-w-7xl mx-auto px-6 py-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-mono text-[10px] uppercase tracking-wider">
        © {year} MATT WRIGHT · MATTWRIGHT.ETH
      </p>
      <div class="flex gap-4">
        <a
          href="https://twitter.com/mattwright_eth"
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-[10px] uppercase tracking-wider hover:text-amber transition-colors"
        >
          TWITTER
        </a>
        <a
          href="https://warpcast.com/mattwright.eth"
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-[10px] uppercase tracking-wider hover:text-amber transition-colors"
        >
          FARCASTER
        </a>
        <a
          href="https://github.com/MateoDev"
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-[10px] uppercase tracking-wider hover:text-amber transition-colors"
        >
          GITHUB
        </a>
      </div>
    </div>
  </div>
</footer>
