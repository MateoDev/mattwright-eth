---
interface Props {
  slug: string;
  title: string;
  category: string;
  date: Date;
  readingTime: number;
}

const { slug, title, category, date, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).replace(/\//g, '·');
---

<a href={`/${slug}`} class="receipt-card block p-6 group">
  <!-- Header: Tag and Date -->
  <div class="flex justify-between items-center mb-3">
    <span class="font-mono text-[10px] uppercase tracking-wider">
      [{category}]
    </span>
    <span class="font-mono text-[10px] tracking-wider">
      {formattedDate}
    </span>
  </div>

  <!-- Divider -->
  <div class="divider-thin mb-4"></div>

  <!-- Title -->
  <h3 class="font-grotesk text-xl font-bold mb-4 group-hover:text-amber transition-colors">
    {title}
  </h3>

  <!-- Footer: Read time and arrow -->
  <div class="flex justify-between items-center">
    <span class="font-mono text-[11px] tracking-wider">
      ~{readingTime} min read
    </span>
    <span class="font-mono text-[11px] text-amber">
      →
    </span>
  </div>
</a>
