---
---
<div class="fig-wrap">
  <div class="fig-label">FIGURE 04 — AGENT RESOURCE STACK</div>
  <div class="stack-grid">
    <div class="stack-col">
      <div class="stack-header">
        <div class="stack-icon">⚙</div>
        <div class="stack-title">COMPUTE</div>
      </div>
      <div class="stack-panel">
        <div class="provider">
          <div class="provider-name">Gaia Network</div>
          <div class="provider-desc">Decentralized inference nodes</div>
          <div class="provider-tag">DEPIN</div>
        </div>
        <div class="provider">
          <div class="provider-name">io.net</div>
          <div class="provider-desc">Distributed GPU clusters</div>
          <div class="provider-tag">DEPIN</div>
        </div>
        <div class="provider">
          <div class="provider-name">Hyperbolic</div>
          <div class="provider-desc">On-demand inference</div>
          <div class="provider-tag">MARKETPLACE</div>
        </div>
        <div class="provider dim">
          <div class="provider-name">AWS / GCP</div>
          <div class="provider-desc">Centralized fallback</div>
          <div class="provider-tag tag-warn">CENTRALIZED</div>
        </div>
      </div>
      <div class="cost-compare">
        <div class="cost-row">
          <span class="cost-label">Decentralized</span>
          <div class="cost-bar"><div class="cost-fill" style="width:28%; background:#5a9a5a"></div></div>
          <span class="cost-val">~$0.28/hr</span>
        </div>
        <div class="cost-row">
          <span class="cost-label">Centralized</span>
          <div class="cost-bar"><div class="cost-fill" style="width:100%; background:#555"></div></div>
          <span class="cost-val">~$1.00/hr</span>
        </div>
      </div>
    </div>

    <div class="stack-col stack-col--mid">
      <div class="stack-header">
        <div class="stack-icon">◈</div>
        <div class="stack-title">CONTEXT & INFERENCE</div>
      </div>
      <div class="stack-panel">
        <div class="provider">
          <div class="provider-name">RAG Pipelines</div>
          <div class="provider-desc">Real-time knowledge retrieval</div>
          <div class="provider-tag">DYNAMIC</div>
        </div>
        <div class="provider">
          <div class="provider-name">Vector Databases</div>
          <div class="provider-desc">Pinecone, Chroma, pgvector</div>
          <div class="provider-tag">STORAGE</div>
        </div>
        <div class="provider">
          <div class="provider-name">Domain Knowledge Bases</div>
          <div class="provider-desc">Gaia nodes, fine-tuned LLMs</div>
          <div class="provider-tag">SPECIALIZED</div>
        </div>
        <div class="provider">
          <div class="provider-name">Memory Systems</div>
          <div class="provider-desc">Session + long-term context</div>
          <div class="provider-tag">STATEFUL</div>
        </div>
      </div>
      <div class="agent-query">
        <div class="query-label">AGENT QUERY FLOW</div>
        <div class="query-step">1. Receive task intent</div>
        <div class="query-step">2. Retrieve relevant context</div>
        <div class="query-step">3. Select optimal model</div>
        <div class="query-step">4. Execute + log result</div>
      </div>
    </div>

    <div class="stack-col">
      <div class="stack-header">
        <div class="stack-icon">⬡</div>
        <div class="stack-title">EXTENSIBLE TOOLS</div>
      </div>
      <div class="stack-panel">
        <div class="provider">
          <div class="provider-name">MCP Servers</div>
          <div class="provider-desc">Standardized tool discovery</div>
          <div class="provider-tag">PROTOCOL</div>
        </div>
        <div class="provider">
          <div class="provider-name">REST / GraphQL APIs</div>
          <div class="provider-desc">External service integrations</div>
          <div class="provider-tag">INTEGRATION</div>
        </div>
        <div class="provider">
          <div class="provider-name">x402 Endpoints</div>
          <div class="provider-desc">Pay-per-call at protocol layer</div>
          <div class="provider-tag">PAYMENTS</div>
        </div>
        <div class="provider">
          <div class="provider-name">A2A Protocol</div>
          <div class="provider-desc">Agent-to-agent communication</div>
          <div class="provider-tag">COORDINATION</div>
        </div>
      </div>
      <div class="tool-count">
        <div class="count-num">10,000+</div>
        <div class="count-label">Tools discoverable by a single agent at runtime</div>
      </div>
    </div>
  </div>
  <div class="fig-caption">Agents don't juggle complexity — they optimize across it in milliseconds.</div>
</div>

<style>
  .fig-wrap {
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    background: #111;
    padding: 24px;
    margin: 2.5em 0;
    font-family: 'IBM Plex Mono', monospace;
  }
  .fig-label {
    font-size: 10px;
    letter-spacing: 0.1em;
    color: #555;
    margin-bottom: 20px;
    text-transform: uppercase;
  }
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .stack-col {
    background: #181818;
    border: 1px solid #2a2a2a;
    border-radius: 3px;
    padding: 14px;
  }
  .stack-col--mid { border-color: #3a3a5a; background: #16161e; }
  .stack-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid #2a2a2a;
  }
  .stack-icon { font-size: 14px; color: #555; }
  .stack-col--mid .stack-icon { color: #7a7aaa; }
  .stack-title {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: #888;
    text-transform: uppercase;
  }
  .stack-col--mid .stack-title { color: #9a9aaa; }
  .stack-panel { display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px; }
  .provider {
    background: #111;
    border: 1px solid #222;
    border-radius: 2px;
    padding: 8px 10px;
  }
  .provider.dim { opacity: 0.5; }
  .provider-name { font-size: 11px; color: #c0c0c0; margin-bottom: 2px; }
  .provider-desc { font-size: 10px; color: #555; margin-bottom: 5px; line-height: 1.3; }
  .provider-tag {
    display: inline-block;
    font-size: 8px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: #222;
    color: #666;
    padding: 1px 5px;
    border-radius: 2px;
  }
  .tag-warn { background: #2a2000; color: #888; }
  .cost-compare { display: flex; flex-direction: column; gap: 6px; }
  .cost-row { display: flex; align-items: center; gap: 6px; font-size: 9px; }
  .cost-label { color: #555; min-width: 72px; }
  .cost-bar { flex: 1; height: 3px; background: #222; border-radius: 2px; overflow: hidden; }
  .cost-fill { height: 100%; border-radius: 2px; }
  .cost-val { color: #888; white-space: nowrap; }
  .agent-query {
    background: #111;
    border: 1px solid #2a2a3a;
    border-radius: 2px;
    padding: 10px;
  }
  .query-label { font-size: 9px; color: #444; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px; }
  .query-step { font-size: 10px; color: #666; margin-bottom: 4px; }
  .query-step::before { content: "›"; margin-right: 6px; color: #7a7aaa; }
  .tool-count {
    background: #111;
    border: 1px solid #222;
    border-radius: 2px;
    padding: 12px;
    text-align: center;
  }
  .count-num { font-size: 22px; color: #e0e0e0; font-weight: 500; margin-bottom: 4px; }
  .count-label { font-size: 9px; color: #555; line-height: 1.4; }
  .fig-caption {
    font-size: 11px;
    color: #555;
    margin-top: 16px;
    text-align: center;
    font-style: italic;
  }
  @media (max-width: 560px) {
    .stack-grid { grid-template-columns: 1fr; }
  }
</style>
