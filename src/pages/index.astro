---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Base title="Matt Wright's website">
  <div style="font-family: 'Space Mono', monospace; font-size: 13px; margin-bottom: 32px;">
    <strong>Matt Wright</strong> · <a href="/about">about</a> · <a href="https://github.com/MateoDev" target="_blank">github</a>
  </div>

  {posts.map((post) => (
    <div class="post-entry">
      <span class="post-date">{formatDate(post.data.date)}</span>
      <h3><a href={`/${post.id}`}>{post.data.title}</a></h3>
    </div>
  ))}
</Base>
