---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base>
  <Header />

  <main class="flex-1">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 py-20 md:py-32">
      <div class="max-w-3xl">
        <h1 class="font-grotesk text-5xl md:text-7xl font-bold mb-6 leading-tight">
          MATT WRIGHT
        </h1>
        <p class="font-inter text-xl md:text-2xl text-dead-black/80 mb-10 leading-relaxed">
          Building agentic infrastructure. Writing about AI, web3, and what comes next.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#writing" class="btn-brutalist">
            READ WRITING →
          </a>
          <a
            href="https://github.com/MateoDev"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-brutalist"
          >
            GITHUB →
          </a>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="divider-thick"></div>

    <!-- Recent Writing Section -->
    <section id="writing" class="max-w-7xl mx-auto px-6 py-16 md:py-20">
      <h2 class="font-mono text-[11px] uppercase tracking-wider mb-8">
        RECENT WRITING
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map((post) => (
          <PostCard
            slug={post.id}
            title={post.data.title}
            category={post.data.category}
            date={post.data.date}
            readingTime={post.data.readingTime}
          />
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Base>
