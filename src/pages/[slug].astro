---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Base from '../layouts/Base.astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base title={`${post.data.title} — Matt Wright`} description={post.data.description}>
  <div class="post-nav">
    <a href="/" class="back-link">← Writing</a>
    <span class="post-cat-label">{post.data.category}</span>
  </div>

  <div class="post-header">
    {post.data.chapter && (
      <div class="chapter-label">{post.data.chapter}</div>
    )}
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      {formatDate(post.data.date)}
      {post.data.readTime && <span> · {post.data.readTime} read</span>}
      {post.data.excerpt && <span> · excerpt</span>}
    </div>
  </div>

  {post.data.forum_url && (
    <div class="forum-callout">
      <span class="forum-callout-label">// cross-posted</span>
      <a href={post.data.forum_url} target="_blank" rel="noopener noreferrer">
        Originally posted on {post.data.forum_name || 'Forum'} →
      </a>
    </div>
  )}

  <div class="markdown-body">
    <Content />
  </div>

  {post.data.forum_url && (
    <div class="forum-callout forum-callout-bottom">
      <span class="forum-callout-label">// discuss</span>
      <a href={post.data.forum_url} target="_blank" rel="noopener noreferrer">
        Join the discussion on {post.data.forum_name || 'Forum'} →
      </a>
    </div>
  )}

  <div class="post-footer">
    <a href="/" class="back-link">← Back to writing</a>
  </div>
</Base>

<style>
  .post-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
  }

  .back-link {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: #888;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .back-link:hover { color: var(--ink); opacity: 1; }

  /* Chapter label for fiction */
  .chapter-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: 8px;
  }

  /* Fiction prose — slightly more generous line height */
  :global(.markdown-body .fiction-prose) {
    font-size: 18px;
    line-height: 2;
  }

  /* Forum cross-post callout */
  .forum-callout {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    border: 1px solid var(--faint);
    border-left: 2px solid var(--ink);
    padding: 10px 14px;
    margin-bottom: 32px;
    color: var(--muted);
  }
  .forum-callout-bottom {
    margin-top: 40px;
    margin-bottom: 0;
  }
  .forum-callout-label {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 10px;
    flex-shrink: 0;
  }
  .forum-callout a {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--faint);
  }
  .forum-callout a:hover {
    text-decoration-color: var(--ink);
    opacity: 1;
  }

  .post-cat-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    border: 1px solid var(--faint);
    padding: 3px 8px;
    border-radius: 2px;
  }

  .post-header {
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 2px solid var(--ink);
  }

  h1 {
    font-size: 2em;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 12px;
    color: var(--ink);
  }

  .post-meta {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .post-footer {
    margin-top: 60px;
    padding-top: 24px;
    border-top: 1px solid var(--faint);
  }

  /* Prose styles */
  .markdown-body {
    font-size: 17px;
    line-height: 1.85;
    color: var(--ink);
  }

  .markdown-body :global(h2) {
    font-size: 1.3em;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-top: 2.5em;
    margin-bottom: 0.6em;
    color: var(--ink);
  }

  .markdown-body :global(h3) {
    font-size: 1.05em;
    font-weight: 600;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: var(--ink);
  }

  .markdown-body :global(p) {
    margin-bottom: 1.4em;
  }

  .markdown-body :global(a) {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--faint);
  }

  .markdown-body :global(a:hover) {
    text-decoration-color: var(--ink);
    opacity: 1;
  }

  .markdown-body :global(strong) {
    font-weight: 600;
  }

  .markdown-body :global(em) {
    font-style: italic;
  }

  .markdown-body :global(blockquote) {
    border-left: 3px solid var(--faint);
    padding-left: 1.2em;
    margin: 1.8em 0;
    color: var(--muted);
    font-style: italic;
  }

  .markdown-body :global(ul),
  .markdown-body :global(ol) {
    padding-left: 1.4em;
    margin-bottom: 1.4em;
  }

  .markdown-body :global(li) {
    margin-bottom: 0.5em;
    line-height: 1.7;
  }

  .markdown-body :global(hr) {
    border: none;
    border-top: 1px solid var(--faint);
    margin: 2.5em 0;
  }

  .markdown-body :global(img) {
    max-width: 100%;
    width: 100%;
    height: auto;
    display: block;
    margin: 1.2em auto;
  }

  .markdown-body :global(code) {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.875em;
    background: var(--faint);
    padding: 2px 5px;
    border-radius: 2px;
  }

  .markdown-body :global(pre) {
    background: var(--ink);
    color: var(--bg);
    padding: 20px;
    overflow-x: auto;
    margin: 1.5em 0;
  }

  .markdown-body :global(pre code) {
    background: none;
    padding: 0;
    font-size: 14px;
  }

  /* Table */
  .markdown-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin: 2em 0;
    font-family: 'IBM Plex Mono', monospace;
  }
  .markdown-body :global(th),
  .markdown-body :global(td) {
    border: 1px solid var(--faint);
    padding: 8px 12px;
    text-align: left;
    color: var(--ink);
  }
  .markdown-body :global(th) {
    background: var(--faint);
    font-weight: 600;
  }

  @media (max-width: 600px) {
    h1 { font-size: 1.6em; }
    .markdown-body { font-size: 16px; }
    .markdown-body :global(img) { width: 100%; height: auto; }
    .markdown-body { font-size: 12px !important; }
  }
</style>
