---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Base from '../layouts/Base.astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base title={`${post.data.title} — Matt Wright`} description={post.data.description}>
  <div class="post-nav">
    <a href="/" class="back-link">← Writing</a>
    <div style="display:flex;align-items:center;gap:12px">
      <span class="post-cat-label">{post.data.category}</span>
      <button id="theme-toggle" class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle dark mode">
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/>
            <line x1="12" y1="2" x2="12" y2="4"/>
            <line x1="12" y1="20" x2="12" y2="22"/>
            <line x1="2" y1="12" x2="4" y2="12"/>
            <line x1="20" y1="12" x2="22" y2="12"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>
    </div>
  </div>

  <div class="post-header">
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      {formatDate(post.data.date)}
      {post.data.readTime && <span> · {post.data.readTime} read</span>}
    </div>
  </div>

  <div class="markdown-body">
    <Content />
  </div>

  <div class="post-footer">
    <a href="/" class="back-link">← Back to writing</a>
  </div>
</Base>

<style>
  .post-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
  }

  .back-link {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: #888;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .back-link:hover { color: var(--ink); opacity: 1; }

  .post-cat-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    border: 1px solid var(--faint);
    padding: 3px 8px;
    border-radius: 2px;
  }

  .post-header {
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 2px solid var(--ink);
  }

  h1 {
    font-size: 2em;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 12px;
    color: var(--ink);
  }

  .post-meta {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .post-footer {
    margin-top: 60px;
    padding-top: 24px;
    border-top: 1px solid var(--faint);
  }

  /* Prose styles */
  .markdown-body {
    font-size: 17px;
    line-height: 1.85;
    color: var(--ink);
  }

  .markdown-body :global(h2) {
    font-size: 1.3em;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-top: 2.5em;
    margin-bottom: 0.6em;
    color: var(--ink);
  }

  .markdown-body :global(h3) {
    font-size: 1.05em;
    font-weight: 600;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: var(--ink);
  }

  .markdown-body :global(p) {
    margin-bottom: 1.4em;
  }

  .markdown-body :global(a) {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--faint);
  }

  .markdown-body :global(a:hover) {
    text-decoration-color: var(--ink);
    opacity: 1;
  }

  .markdown-body :global(strong) {
    font-weight: 600;
  }

  .markdown-body :global(em) {
    font-style: italic;
  }

  .markdown-body :global(blockquote) {
    border-left: 3px solid var(--faint);
    padding-left: 1.2em;
    margin: 1.8em 0;
    color: var(--muted);
    font-style: italic;
  }

  .markdown-body :global(ul),
  .markdown-body :global(ol) {
    padding-left: 1.4em;
    margin-bottom: 1.4em;
  }

  .markdown-body :global(li) {
    margin-bottom: 0.5em;
    line-height: 1.7;
  }

  .markdown-body :global(hr) {
    border: none;
    border-top: 1px solid var(--faint);
    margin: 2.5em 0;
  }

  .markdown-body :global(img) {
    max-width: 100%;
    width: 100%;
    height: auto;
    max-height: 480px;
    object-fit: cover;
    display: block;
    margin: 2em auto;
  }

  .markdown-body :global(code) {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.875em;
    background: var(--faint);
    padding: 2px 5px;
    border-radius: 2px;
  }

  .markdown-body :global(pre) {
    background: var(--ink);
    color: var(--bg);
    padding: 20px;
    overflow-x: auto;
    margin: 1.5em 0;
  }

  .markdown-body :global(pre code) {
    background: none;
    padding: 0;
    font-size: 14px;
  }

  /* Table */
  .markdown-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin: 2em 0;
    font-family: 'IBM Plex Mono', monospace;
  }
  .markdown-body :global(th),
  .markdown-body :global(td) {
    border: 1px solid var(--faint);
    padding: 8px 12px;
    text-align: left;
    color: var(--ink);
  }
  .markdown-body :global(th) {
    background: var(--faint);
    font-weight: 600;
  }

  @media (max-width: 600px) {
    h1 { font-size: 1.6em; }
    .markdown-body { font-size: 16px; }
    .markdown-body :global(img) { max-height: 280px; }
  }
</style>
