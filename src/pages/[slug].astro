---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Base from '../layouts/Base.astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base title={`${post.data.title} — Matt Wright`} description={post.data.description}>
  <div class="post-nav">
    <a href="/" class="back-link">← Writing</a>
    <span class="post-cat-label">{post.data.category}</span>
  </div>

  <div class="post-header">
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      {formatDate(post.data.date)}
      {post.data.readTime && <span> · {post.data.readTime} read</span>}
    </div>
  </div>

  <div class="markdown-body">
    <Content />
  </div>

  <div class="post-footer">
    <a href="/" class="back-link">← Back to writing</a>
  </div>
</Base>

<style>
  .post-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
  }

  .back-link {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: #888;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .back-link:hover { color: #1a1a1a; }

  .post-cat-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #bbb;
    border: 1px solid #e0e0e0;
    padding: 3px 8px;
    border-radius: 2px;
  }

  .post-header {
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 2px solid #1a1a1a;
  }

  h1 {
    font-size: 2em;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 12px;
    color: #1a1a1a;
  }

  .post-meta {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: #999;
    letter-spacing: 0.02em;
  }

  .post-footer {
    margin-top: 60px;
    padding-top: 24px;
    border-top: 1px solid #eee;
  }

  /* Prose styles */
  .markdown-body {
    font-size: 17px;
    line-height: 1.85;
    color: #1a1a1a;
  }

  .markdown-body :global(h2) {
    font-size: 1.3em;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-top: 2.5em;
    margin-bottom: 0.6em;
    color: #1a1a1a;
  }

  .markdown-body :global(h3) {
    font-size: 1.05em;
    font-weight: 600;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: #1a1a1a;
  }

  .markdown-body :global(p) {
    margin-bottom: 1.4em;
  }

  .markdown-body :global(a) {
    color: #1a1a1a;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .markdown-body :global(a:hover) {
    color: #000;
    text-decoration: none;
  }

  .markdown-body :global(strong) {
    font-weight: 600;
  }

  .markdown-body :global(em) {
    font-style: italic;
  }

  .markdown-body :global(blockquote) {
    border-left: 3px solid #ddd;
    padding-left: 1.2em;
    margin: 1.8em 0;
    color: #555;
    font-style: italic;
  }

  .markdown-body :global(ul),
  .markdown-body :global(ol) {
    padding-left: 1.4em;
    margin-bottom: 1.4em;
  }

  .markdown-body :global(li) {
    margin-bottom: 0.5em;
    line-height: 1.7;
  }

  .markdown-body :global(hr) {
    border: none;
    border-top: 1px solid #e0e0e0;
    margin: 2.5em 0;
  }

  /* Image handling — the key fix */
  .markdown-body :global(img) {
    max-width: 100%;
    width: 100%;
    height: auto;
    max-height: 480px;
    object-fit: cover;
    display: block;
    margin: 2em auto;
    border-radius: 4px;
  }

  /* Caption (em directly after img) */
  .markdown-body :global(p:has(img) + p > em:only-child),
  .markdown-body :global(p > em:first-child:last-child) {
    display: block;
    font-size: 13px;
    color: #888;
    text-align: center;
    margin-top: -1.2em;
    margin-bottom: 2em;
    font-style: normal;
  }

  /* Code */
  .markdown-body :global(code) {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.875em;
    background: #f5f5f5;
    padding: 2px 5px;
    border-radius: 3px;
  }

  .markdown-body :global(pre) {
    background: #1a1a1a;
    color: #e8e8e8;
    padding: 20px;
    border-radius: 4px;
    overflow-x: auto;
    margin: 1.5em 0;
  }

  .markdown-body :global(pre code) {
    background: none;
    padding: 0;
    font-size: 14px;
  }

  @media (max-width: 600px) {
    h1 { font-size: 1.6em; }
    .markdown-body { font-size: 16px; }
    .markdown-body :global(img) { max-height: 280px; }
  }
</style>
