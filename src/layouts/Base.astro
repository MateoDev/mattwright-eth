---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Matt Wright",
  description = 'Writing about AI, sovereign intelligence, and the agentic future.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }

      :root {
        --ink: #111;
        --muted: #777;
        --faint: #e8e8e8;
        --bg: #fff;
        --mono: 'IBM Plex Mono', 'Courier New', monospace;
        --sans: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, sans-serif;
        --max: 660px;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --ink: #f0f0f0;
          --muted: #888;
          --faint: #2a2a2a;
          --bg: #141414;
        }
      }

      html { font-size: 16px; }

      body {
        font-family: var(--sans);
        font-size: 1rem;
        line-height: 1.75;
        max-width: var(--max);
        margin: 48px auto;
        padding: 0 24px;
        color: var(--ink);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
      }

      a { color: var(--ink); }
      a:hover { opacity: 0.6; }

      /* ── INDEX PAGE ─────────────────────── */
      .site-header { margin-bottom: 36px; }
      .site-nav {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 10px;
      }
      .site-name {
        font-family: var(--mono);
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--ink);
        text-decoration: none;
      }
      .nav-links {
        display: flex;
        gap: 18px;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.03em;
        text-transform: uppercase;
      }
      .nav-links a { color: var(--muted); text-decoration: none; }
      .nav-links a:hover { color: var(--ink); opacity: 1; }

      .site-bio {
        font-size: 14px;
        line-height: 1.65;
        color: var(--muted);
        margin: 0;
      }

      /* Category filter */
      .category-bar {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-bottom: 28px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--faint);
      }
      .cat-btn {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 4px 10px;
        border: 1px solid var(--ink);
        background: var(--bg);
        color: var(--ink);
        cursor: pointer;
        border-radius: 2px;
        transition: background 0.1s, color 0.1s;
      }
      .cat-btn:hover, .cat-btn.active {
        background: var(--ink);
        color: var(--bg);
      }

      /* Post list */
      .post-entry {
        display: grid;
        grid-template-columns: 88px 1fr auto;
        align-items: baseline;
        gap: 14px;
        padding: 12px 0;
        border-bottom: 1px solid var(--faint);
      }
      .post-entry:last-child { border-bottom: none; }
      .post-date {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--muted);
        white-space: nowrap;
      }
      .post-title {
        font-size: 15px;
        font-weight: 500;
        color: var(--ink);
        text-decoration: none;
        letter-spacing: -0.01em;
        line-height: 1.4;
      }
      .post-title:hover { opacity: 0.65; text-decoration: none; }
      .post-cat-tag {
        font-family: var(--mono);
        font-size: 10px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        white-space: nowrap;
      }

      /* ── POST PAGE ───────────────────────── */
      .post-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
      }
      .back-link {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        text-decoration: none;
      }
      .back-link:hover { color: var(--ink); opacity: 1; }
      .post-cat-label {
        font-family: var(--mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        border: 1px solid var(--faint);
        padding: 3px 8px;
        border-radius: 2px;
      }

      .post-header {
        margin-bottom: 40px;
        padding-bottom: 24px;
        border-bottom: 2px solid var(--ink);
      }
      .post-header h1 {
        font-family: var(--mono);
        font-size: 1.6em;
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.25;
        margin: 0 0 12px 0;
        color: var(--ink);
      }
      .post-meta {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--muted);
        letter-spacing: 0.03em;
        text-transform: uppercase;
      }

      /* ── PROSE ───────────────────────────── */
      .markdown-body {
        font-size: 17px;
        line-height: 1.85;
        color: var(--ink);
      }
      .markdown-body h2 {
        font-family: var(--mono);
        font-size: 1em;
        font-weight: 500;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-top: 3em;
        margin-bottom: 0.8em;
        color: var(--ink);
      }
      .markdown-body h3 {
        font-family: var(--sans);
        font-size: 1.05em;
        font-weight: 600;
        margin-top: 2em;
        margin-bottom: 0.5em;
      }
      .markdown-body p { margin-bottom: 1.4em; }
      .markdown-body a {
        color: var(--ink);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: var(--faint);
      }
      .markdown-body a:hover {
        text-decoration-color: var(--ink);
        opacity: 1;
      }
      .markdown-body strong { font-weight: 600; }
      .markdown-body em { font-style: italic; }
      .markdown-body blockquote {
        border-left: 2px solid var(--ink);
        padding-left: 1.2em;
        margin: 2em 0;
        color: var(--muted);
        font-style: italic;
      }
      .markdown-body ul, .markdown-body ol {
        padding-left: 1.4em;
        margin-bottom: 1.4em;
      }
      .markdown-body li { margin-bottom: 0.5em; line-height: 1.7; }
      .markdown-body hr {
        border: none;
        border-top: 1px solid var(--faint);
        margin: 3em 0;
      }

      /* Images — responsive, constrained */
      .markdown-body img {
        display: block;
        width: 100%;
        max-width: 100%;
        height: auto;
        max-height: 440px;
        object-fit: cover;
        margin: 2.5em auto;
        border-radius: 3px;
      }

      /* Caption — italic em right after an image paragraph */
      .markdown-body p:has(img) + p,
      .markdown-body p:has(img) ~ p:first-of-type {
        font-size: 12px;
        color: var(--muted);
        text-align: center;
        margin-top: -1.8em;
        margin-bottom: 2.5em;
        font-style: italic;
        font-family: var(--mono);
      }

      .markdown-body code {
        font-family: var(--mono);
        font-size: 0.85em;
        background: var(--faint);
        padding: 2px 5px;
        border-radius: 2px;
      }
      .markdown-body pre {
        background: var(--ink);
        color: var(--bg);
        padding: 20px;
        border-radius: 3px;
        overflow-x: auto;
        margin: 1.5em 0;
        font-size: 14px;
      }
      .markdown-body pre code { background: none; padding: 0; }

      .post-footer {
        margin-top: 60px;
        padding-top: 24px;
        border-top: 1px solid var(--faint);
      }

      /* ── MOBILE ──────────────────────────── */
      @media (max-width: 560px) {
        body { margin: 24px auto; padding: 0 18px; }
        .post-entry { grid-template-columns: 1fr; gap: 3px; }
        .post-date { display: none; }
        .post-cat-tag { display: none; }
        .site-nav { flex-direction: column; gap: 10px; }
        .post-header h1 { font-size: 1.3em; }
        .markdown-body { font-size: 16px; }
        .markdown-body img { max-height: 260px; }
      }
    </style>
  </head>
  <body>
    <div id="doc">
      <slot />
    </div>
  </body>
</html>
