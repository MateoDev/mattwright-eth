---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    category: string;
    readingTime: number;
    ogImage?: string;
  };
}

const { frontmatter } = Astro.props;
const { title, description, date, category, readingTime, ogImage } = frontmatter;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${title} - Matt Wright`} description={description} image={ogImage}>
  <Header />

  <main class="flex-1 py-12">
    <article class="max-w-4xl mx-auto px-6">
      <!-- Back link -->
      <a
        href="/"
        class="inline-block font-mono text-[11px] uppercase tracking-wider mb-8 hover:text-amber transition-colors"
      >
        ← WRITING
      </a>

      <!-- Article header -->
      <div class="mb-12">
        <div class="divider-thick mb-8"></div>

        <h1 class="font-grotesk text-4xl md:text-5xl font-bold mb-6">
          {title}
        </h1>

        <div class="divider-thin mb-4"></div>

        <div class="font-mono text-[12px] uppercase tracking-wider flex flex-wrap gap-2 items-center">
          <span>{formattedDate}</span>
          <span>·</span>
          <span>{category}</span>
          <span>·</span>
          <span>~{readingTime} MIN READ</span>
        </div>

        <div class="divider-thin mt-4"></div>
      </div>

      <!-- Article content -->
      <div class="prose prose-lg max-w-none">
        <slot />
      </div>

      <!-- Bottom navigation -->
      <div class="mt-16 pt-8 border-t-4 border-dead-black">
        <a
          href="/"
          class="inline-block font-mono text-[11px] uppercase tracking-wider hover:text-amber transition-colors"
        >
          ← BACK TO WRITING
        </a>
      </div>
    </article>
  </main>

  <Footer />
</Base>

<style>
  .prose {
    @apply text-dead-black;
  }

  .prose :global(h2) {
    @apply font-grotesk text-2xl font-bold mt-12 mb-4;
  }

  .prose :global(h3) {
    @apply font-grotesk text-xl font-bold mt-8 mb-3;
  }

  .prose :global(p) {
    @apply font-inter text-lg leading-relaxed mb-6;
  }

  .prose :global(a) {
    @apply text-amber underline hover:no-underline;
  }

  .prose :global(ul),
  .prose :global(ol) {
    @apply mb-6 ml-6;
  }

  .prose :global(li) {
    @apply mb-2;
  }

  .prose :global(strong) {
    @apply font-semibold;
  }

  .prose :global(blockquote) {
    @apply border-l-4 border-amber pl-6 italic my-6;
  }
</style>
